# Prompt-regression runner configuration. Copy to `.env` and fill in ONE
# provider's key (never commit real keys). The runner reads plain env vars,
# so either `export` these or use a tool like dotenv/direnv.

# Which provider to grade against: anthropic | openai | gemini
OOAD_PROVIDER=anthropic

# Optional model override (defaults: claude-sonnet-5 / gpt-4o / gemini-1.5-pro)
# OOAD_MODEL=claude-sonnet-5

# Provide the key for the provider you selected above (only one is needed):
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
